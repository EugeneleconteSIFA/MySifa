{
  "name": "myprod-widget",
  "version": "1.0.0",
  "description": "Widget de bureau MySifa - Statut machines Cohésio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "keywords": ["mysifa", "production", "widget", "industrie"],
  "author": "SIFA",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "pro.sifa.myprod-widget",
    "productName": "MyProd Widget",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "artifactName": "MyProd-Widget-${version}-${arch}.dmg"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MyProd Widget",
      "uninstallDisplayName": "MyProd Widget",
      "artifactName": "MyProd-Widget-${version}-Setup.exe"
    }
  }
}
