# Copier vers .env et renseigner les valeurs (ne jamais committer .env)

# Base de données (local par défaut : data/production.db)
# DB_PATH=/chemin/vers/production.db

# Email — Microsoft Graph (recommandé en prod M365)
SUPPORT_EMAIL_PROVIDER=graph
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_SENDER_UPN=expeditions@sifa.pro

# Email — SMTP (fallback si Graph indisponible)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=motdepasse
SMTP_FROM=noreply@mysifa.fr
SMTP_FROM_NAME=MySifa
# Liens portail transporteur / emails (prod : https://www.mysifa.com)
BASE_URL=https://www.mysifa.com
# Optionnel : surcharge explicite (sinon BASE_URL, sinon https://www.mysifa.com)
# PUBLIC_BASE_URL=https://www.mysifa.com

# Chat — GIFs (clé gratuite sur developers.giphy.com)
GIPHY_API_KEY=votre_clé_ici

# Racine des pièces jointes chat/avatars/traca (servies via /uploads/*).
# Sur v1 (staging), pointer sur le dossier de v2 pour partager les fichiers,
# comme la DB. Sinon les pièces jointes envoyées depuis l'autre instance
# retournent 404. Défaut : <BASE_DIR>/uploads.
# UPLOADS_ROOT=/home/sifa/production-saas/uploads
