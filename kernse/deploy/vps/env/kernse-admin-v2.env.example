# Kernse — Environnement kernse-admin v2 (production)
# À déployer :
#   sudo cp kernse-admin-v2.env.example /home/kernse/env/kernse-admin-v2.env
#   sudo chown kernse:kernse /home/kernse/env/kernse-admin-v2.env
#   sudo chmod 600 /home/kernse/env/kernse-admin-v2.env
# Puis éditer et remplir les valeurs.

# --- Auth superadmin (obligatoire au premier boot) ---
# Le 1er compte superadmin plateforme est créé automatiquement à partir
# de ces valeurs si aucun superadmin n'existe en DB. Après création,
# changer le mot de passe via la console et retirer ces variables.
KERNSE_BOOTSTRAP_EMAIL=eleconte@sifa.pro
KERNSE_BOOTSTRAP_PASSWORD=CHANGE_MOI_AU_PREMIER_LOGIN_MIN_12_CHAR

# --- Cookie & session (généré aléatoirement au 1er boot si absent) ---
# Générer un secret solide : openssl rand -hex 32
KERNSE_ADMIN_SECRET_KEY=REMPLACE_MOI_PAR_UN_SECRET_HEX_DE_64_CHARS

# --- Chemins ---
KERNSE_INSTANCES_ROOT=/home/kernse/instances
KERNSE_METIER_REPO_URL=https://github.com/EugeneleconteSIFA/MySifa.git
KERNSE_METIER_BRANCH=main
KERNSE_TEMPLATES_DIR=/home/kernse/platform/kernse/provisioning/templates
KERNSE_STARTER_KITS_DIR=/home/kernse/platform/kernse/seeds/starter_kits
KERNSE_NGINX_SITES=/etc/nginx/sites-available
KERNSE_NGINX_ENABLED=/etc/nginx/sites-enabled
KERNSE_SYSTEMD_DIR=/etc/systemd/system

# --- Marque affichée dans la console (paramétrable) ---
KERNSE_DEFAULT_APP_NAME=Kernse
