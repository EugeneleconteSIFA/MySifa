# Kernse — Environnement kernse-admin v1 (staging)
# CE FICHIER EST POUR L'INSTANCE V1 — les actions faites via la console
# admin-v1 affectent le vrai VPS (systemd, nginx). C'est le banc de test
# des scripts de provisioning eux-mêmes.

KERNSE_BOOTSTRAP_EMAIL=eleconte@sifa.pro
KERNSE_BOOTSTRAP_PASSWORD=CHANGE_MOI_AU_PREMIER_LOGIN_MIN_12_CHAR

KERNSE_ADMIN_SECRET_KEY=REMPLACE_MOI_PAR_UN_SECRET_HEX_DE_64_CHARS_DIFFERENT_DE_V2

KERNSE_INSTANCES_ROOT=/home/kernse/instances
KERNSE_METIER_REPO_URL=https://github.com/EugeneleconteSIFA/MySifa.git
KERNSE_METIER_BRANCH=staging
KERNSE_TEMPLATES_DIR=/home/kernse/platform-v1/kernse/provisioning/templates
KERNSE_STARTER_KITS_DIR=/home/kernse/platform-v1/kernse/seeds/starter_kits
KERNSE_NGINX_SITES=/etc/nginx/sites-available
KERNSE_NGINX_ENABLED=/etc/nginx/sites-enabled
KERNSE_SYSTEMD_DIR=/etc/systemd/system

KERNSE_DEFAULT_APP_NAME=Kernse
